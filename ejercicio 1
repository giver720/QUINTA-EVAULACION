#include <iostream>
using namespace std;

int main() {
    float arreglo[10] = {3.14, 7.25, 1.89, 9.67, 0.45, 5.32, 8.11, 2.76, 6.54, 4.03};
    float maximo = arreglo[0];
    float minimo = arreglo[0];

    for(int i = 1; i < 10; i++) {
        if(arreglo[i] > maximo) {
            maximo = arreglo[i];
        }
        if(arreglo[i] < minimo) {
            minimo = arreglo[i];
        }
    }

    cout << "Valor maximo: " << maximo << endl;
    cout << "Valor minimo: " << minimo << endl;

    return 0;
}
