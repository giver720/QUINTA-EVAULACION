#include <iostream>
using namespace std; 

int main () {

float numeros[]={5.2,8.1,6.4,4.2,8.3,7.1,12.8,5.3,4.4,2.3};
 std::cout << "Ingresa 10 numeros:\n";
    for(int i = 0; i < 10; ++i) {
        std::cin >> numeros[i];
    }
    
int min = numeros[0];
    int max = numeros[0];
    
    for(int i = 1; i < 10; ++i) {
        if(numeros[i] < min) min = numeros[i];
        if(numeros[i] > max) max = numeros[i];
    }
    
    std::cout << "El menor es: " << min << "\n";
    std::cout << "El mayor es: " << max << "\n";
    
    return 0;
}
